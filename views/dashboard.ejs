<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="dashboard-page">
  <div class="container dashboard-container">
    <div class="header">
      <h1>Dashboard</h1>
      <a href="/user/logout" class="button logout-btn"
        style="text-decoration: none; display: inline-block; text-align: center; color: white; border-radius:8px;">Logout</a>
    </div>

    <!-- Form to create new short URL -->
    <form method="POST" action="/url" style="margin-bottom: 30px;">
      <label for="redirectURL">Enter Original URL:</label>
      <div style="display: flex; gap: 10px;">
        <input type="text" id="url" name="url" required placeholder="https://example.com" style="flex:1;" />
        <button type="submit" style="width: auto; margin-top: 0;">Generate Short URL</button>
      </div>
    </form>

    <!-- Table of short URLs -->
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Short URL</th>
          <th>Original URL</th>
          <th>Visit</th>
        </tr>
      </thead>
      <tbody>
        <% if (urls && urls.length> 0) { %>
          <% urls.forEach((url, index)=> { %>
            <tr>
              <td data-label="#">
                <%= index + 1 %>
              </td>
              <td data-label="Short ID">
                <%= url.shortID %>
              </td>
              <td data-label="Original URL">
                <%= url.redirectURL %>
              </td>
              <td data-label="Action">
                <a href="/u/<%= url.shortID %>" target="_blank" class="visit-btn">Visit</a>
              </td>
            </tr>
            <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="4" style="text-align: center;">No URLs created yet</td>
                </tr>
                <% } %>
      </tbody>
    </table>
  </div>
</body>

</html>